        <mxCell id="Q5v_Ab0HL9TnUDys6BRt-54" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Purpose of this stage&lt;/b&gt; is to allow player more &lt;b&gt;rapid production of iron parts&lt;/b&gt; + larger cast parts &lt;b&gt;(indusrtial components&lt;/b&gt;), while requiring low amount of iron to set up and&lt;b&gt; not require steel&lt;/b&gt;." vertex="1">
