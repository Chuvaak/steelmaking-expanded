        <mxCell id="Q5v_Ab0HL9TnUDys6BRt-55" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Blast furnace&lt;/b&gt; running on &lt;b&gt;cold blast &lt;/b&gt;cannot reach high temperatures (will run around 1550 °C) and hence can be built from tier 1 or 2 refractrory bricks, moving the whole setup to&lt;b&gt; iron age&lt;/b&gt;. Make molten iron runs short!" vertex="1">
          <mxGeometry height="70" width="210" x="510" y="215" as="geometry" />
        </mxCell>
        <mxCell id="Q5v_Ab0HL9TnUDys6BRt-57" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Pig iron&lt;/b&gt; is new alloy intemediate product.&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;Wrought iron &lt;/b&gt;is vanilla iron.&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;Cast iron&lt;/b&gt; is new alloy, can be used in vanilla construction recipes instead of iron.&lt;/div&gt;&lt;/div&gt;" vertex="1">
