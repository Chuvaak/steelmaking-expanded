{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-exlib",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/ExpandedLib/ExpandedLib.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-smex",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/SteelmakingExpanded/SteelmakingExpanded.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "stage-mods (exlib, ppex, smex)",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/stage-mods.ps1",
        "-Dest",
        "${workspaceFolder}/bin/Mods",
        "exlib=${workspaceFolder}/src/ExpandedLib/bin/Debug/Mods/mod",
        "smex=${workspaceFolder}/src/SteelmakingExpanded/bin/Debug/Mods/mod",
        "ppex=${workspaceFolder}/src/PipesAndPowerExpanded/bin/Debug/Mods/mod"
      ],
      "linux": {
        "command": "bash",
        "args": [
          "${workspaceFolder}/scripts/stage-mods.sh",
          "-Dest",
          "${workspaceFolder}/bin/Mods",
          "exlib=${workspaceFolder}/src/ExpandedLib/bin/Debug/Mods/mod",
          "smex=${workspaceFolder}/src/SteelmakingExpanded/bin/Debug/Mods/mod",
          "ppex=${workspaceFolder}/src/PipesAndPowerExpanded/bin/Debug/Mods/mod"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "Publish mods",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/build/CakeBuild/CakeBuild.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "link-game (1.22)",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/scripts/link-game.ps1",
        "-Key",
        "VINTAGE_STORY",
        "-Link",
        "bin/game-1.22"
      ],
      "linux": {
        "command": "bash",
        "args": [
          "${workspaceFolder}/scripts/link-game.sh",
          "-Key",
          "VINTAGE_STORY",
          "-Link",
          "bin/game-1.22"
        ]
      },
      "problemMatcher": []
    },
    {
      "label": "launch-prep (smex)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build-smex",
        "stage-mods (exlib, ppex, smex)",
        "link-game (1.22)"
      ],
      "problemMatcher": []
    },

    // ----------------------------------------------------------------------------------------
    // Legacy game versions (1.21 -> net8.0, 1.20 -> net7.0). Opt-in multi-target via -p:Legacy.
    // Install paths come from VINTAGE_STORY_121 / VINTAGE_STORY_120 in the environment, or from
    // the repo-root .env file (see .env.example) - both builds and launch read them from there.
    // build-smex pulls exlib + ppex via project references, so a single build covers the chain.
    // ----------------------------------------------------------------------------------------
    {
      "label": "build-exlib (1.21)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/ExpandedLib/ExpandedLib.csproj",
        "-p:Legacy=true",
        "-p:TargetFramework=net8.0"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-smex (1.21)",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/SteelmakingExpanded/SteelmakingExpanded.csproj",
        "-p:Legacy=true",
        "-p:TargetFramework=net8.0"
      ],
      "problemMatcher": "$msCompile"
    },
