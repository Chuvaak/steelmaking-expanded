{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-exlib",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/ExpandedLib/ExpandedLib.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-ppex",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/PipesAndPowerExpanded/PipesAndPowerExpanded.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-smex",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/SteelmakingExpanded/SteelmakingExpanded.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "stage-mods (exlib, ppex)",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/.vscode/stage-mods.ps1",
        "-Dest",
        "${workspaceFolder}/bin/Mods",
        "exlib=${workspaceFolder}/src/ExpandedLib/bin/Debug/Mods/mod",
        "ppex=${workspaceFolder}/src/PipesAndPowerExpanded/bin/Debug/Mods/mod"
      ],
      "problemMatcher": []
    },
    {
      "label": "stage-mods (exlib, ppex, smex)",
      "type": "process",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-File",
        "${workspaceFolder}/.vscode/stage-mods.ps1",
        "-Dest",
        "${workspaceFolder}/bin/Mods",
        "exlib=${workspaceFolder}/src/ExpandedLib/bin/Debug/Mods/mod",
        "smex=${workspaceFolder}/src/SteelmakingExpanded/bin/Debug/Mods/mod",
        "ppex=${workspaceFolder}/src/PipesAndPowerExpanded/bin/Debug/Mods/mod"
      ],
      "problemMatcher": []
    },
    {
      "label": "Publish mods",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/build/CakeBuild/CakeBuild.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "launch-prep (ppex)",
      "dependsOrder": "sequence",
      "dependsOn": ["build-ppex", "stage-mods (exlib, ppex)"],
      "problemMatcher": []
    },
    {
      "label": "launch-prep (smex)",
      "dependsOrder": "sequence",
      "dependsOn": ["build-smex", "stage-mods (exlib, ppex, smex)"],
      "problemMatcher": []
    }
  ]
}
