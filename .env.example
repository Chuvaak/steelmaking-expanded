# Local VintageStory install paths. Copy this file to ".env" (gitignored) and set each
# variable to your machine's install for that game version.
#
# Used by:
#   - the build (src/Directory.Build.props selects the right install per target framework)
#   - the launch configs (.vscode/launch.json, via "envFile")
#   - the headless test harness (resolves the game assemblies at runtime)
#
# The supported versions and their env-var names live in the manifest in src/Directory.Build.props
# (the single source of truth). When a version is added there, add the matching variable below.
#
# VINTAGE_STORY      -> 1.22 install (.NET 10) - the current/primary target
# VINTAGE_STORY_121  -> 1.21 install (.NET 8)  - legacy target
# VINTAGE_STORY_120  -> 1.20 install (.NET 7)  - legacy target

VINTAGE_STORY=C:/path/to/Vintagestory
VINTAGE_STORY_121=C:/path/to/Vintagestory-1.21
VINTAGE_STORY_120=C:/path/to/Vintagestory-1.20
